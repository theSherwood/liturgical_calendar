{
  "name": "liturgical-calendar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A secular family liturgical calendar: one data source, three synced outputs (.ics, website, PDF).",
  "scripts": {
    "build": "tsx src/build.ts",
    "build:ics": "tsx src/build.ts --only=ics",
    "build:web": "tsx src/build.ts --only=web",
    "build:pdf": "tsx src/build.ts --only=pdf",
    "serve": "tsx src/serve.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "astronomy-engine": "^2.1.19",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "gray-matter": "^4.0.3",
    "ical-generator": "^8.0.1",
    "marked": "^14.1.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "puppeteer": "^23.11.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
